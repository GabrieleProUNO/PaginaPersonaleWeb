---
// Contenuto completo della home (single-page). Condiviso da index.astro (IT)
// e en/index.astro (EN) — niente duplicazione di markup.
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Hero from './Hero.astro';
import CaseStudyCard from './CaseStudyCard.astro';
import GalleryCard from './GalleryCard.astro';
import { useTranslations, type Lang } from '../i18n/utils';
import {
  techProjects, techSkills, collaborations, exhibitions, creativeSkills,
} from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Foto del "Chi sono": opzionale. Basta salvare un'immagine in
// src/assets/about/ (qualsiasi nome) e verrà presa automaticamente.
const aboutImgs = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/about/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG}',
  { eager: true }
);
const aboutPhoto = Object.values(aboutImgs)[0]?.default;
---

<Hero lang={lang} />

<!-- ====================== LOGICA ====================== -->
<section id="logica" class="section" data-section-mode="logica">
  <div class="wrap">
    <header class="section__head">
      <p class="kicker">{t('nav.logica')}</p>
      <h2>{t('logica.title')}</h2>
      <p class="lead">{t('logica.lead')}</p>
    </header>

    <div class="cards-2">
      {techProjects.map((p) => <CaseStudyCard project={p} lang={lang} />)}
    </div>

    <div class="skills">
      <p class="kicker">{t('skills.tech.title')}</p>
      <ul>{techSkills.map((s) => <li class="pill">{s}</li>)}</ul>
    </div>
  </div>
</section>

<!-- ====================== LUCE ====================== -->
<section id="luce" class="section">
  <div class="wrap">
    <header class="section__head">
      <p class="kicker">{t('nav.luce')}</p>
      <h2>{t('luce.title')}</h2>
      <p class="lead">{t('luce.lead')}</p>
    </header>

    <h3 class="section__sub">{t('luce.collab.title')}</h3>
    <div class="cards-2">
      {collaborations.map((c) => (
        <GalleryCard slug={c.slug} title={c.name} desc={c.desc[lang]} lang={lang} />
      ))}
    </div>

    <h3 class="section__sub section__sub--gap">{t('luce.exh.title')}</h3>
    <div class="cards-3">
      {exhibitions.map((e) => (
        <GalleryCard slug={e.slug} title={e.title[lang]} desc={e.desc[lang]} lang={lang} />
      ))}
    </div>

    <div class="skills">
      <p class="kicker">{t('skills.creative.title')}</p>
      <ul>{creativeSkills.map((s) => <li class="pill">{s}</li>)}</ul>
    </div>
  </div>
</section>

<!-- ====================== ABOUT ====================== -->
<section id="about" class="section">
  <div class="wrap about-grid">
    <div class="about-grid__media">
      {aboutPhoto ? (
        <Image src={aboutPhoto} alt="Gabriele Pittui" widths={[400, 720]} sizes="(max-width: 900px) 100vw, 40vw" loading="lazy" />
      ) : (
        <div class="about-grid__placeholder"><span class="kicker">Foto in arrivo</span></div>
      )}
    </div>
    <div class="about-grid__text">
      <header class="section__head">
        <p class="kicker">{t('nav.about')}</p>
        <h2>{t('about.title')}</h2>
      </header>
      {t('about.body').map((p) => <p>{p}</p>)}
      <h3 class="about-coach">{t('about.coach.title')}</h3>
      {t('about.coach.body').map((p) => <p>{p}</p>)}
    </div>
  </div>
</section>

<!-- ====================== CONTACT ====================== -->
<section id="contact" class="section">
  <div class="wrap contact">
    <p class="kicker">{t('nav.contact')}</p>
    <h2>{t('contact.title')}</h2>
    <p class="lead">{t('contact.body')}</p>

    <!-- Form gestito da Netlify Forms: nessun backend, le mail arrivano a Gabriele.
         Il mittente DEVE inserire un'email valida (type=email + required). -->
    <form
      name="contatti"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="contact-form"
      id="contact-form"
    >
      <input type="hidden" name="form-name" value="contatti" />
      <p hidden>
        <label>Non compilare: <input name="bot-field" /></label>
      </p>
      <div class="contact-form__row">
        <label>
          <span>{t('contact.form.name')}</span>
          <input type="text" name="nome" required autocomplete="name" />
        </label>
        <label>
          <span>{t('contact.form.email')}</span>
          <input type="email" name="email" required autocomplete="email" placeholder="nome@esempio.com" />
        </label>
      </div>
      <label>
        <span>{t('contact.form.message')}</span>
        <textarea name="messaggio" rows="4" required></textarea>
      </label>
      <button type="submit" class="btn btn-primary" data-default={t('contact.form.send')} data-sending={t('contact.form.sending')}>
        {t('contact.form.send')}
      </button>
      <p class="contact-form__status" id="contact-status" role="status" aria-live="polite"
         data-ok={t('contact.form.ok')} data-error={t('contact.form.error')}></p>
    </form>

    <p class="contact__or">{t('contact.or')}</p>
    <div class="contact__actions">
      <a class="btn btn-accent" href="mailto:pittuigabriele@gmail.com">pittuigabriele@gmail.com</a>
      <a class="btn btn-ghost" href="tel:+393280911595">328 0911595</a>
      <a class="btn btn-ghost" href="https://instagram.com/pittui_gabriele" target="_blank" rel="noopener noreferrer">@pittui_gabriele</a>
    </div>
  </div>
</section>

<script>
  // Invio AJAX a Netlify Forms: validazione email del browser + feedback inline.
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-status');
  if (form && status) {
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return; // email non valida → blocca
      btn.disabled = true;
      btn.textContent = btn.dataset.sending!;
      status.textContent = '';
      try {
        const data = new FormData(form);
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(data as any).toString(),
        });
        status.textContent = status.dataset.ok!;
        status.classList.add('is-ok');
        form.reset();
      } catch {
        status.textContent = status.dataset.error!;
        status.classList.add('is-error');
      } finally {
        btn.disabled = false;
        btn.textContent = btn.dataset.default!;
      }
    });
  }
</script>

<style>
  .section { padding-block: clamp(72px, 12vh, 128px); border-top: var(--stroke) solid var(--border); }
  .section__head { max-width: 60ch; margin-bottom: 48px; }
  .section__head h2 { margin: 10px 0 16px; }
  .section__sub { font-size: var(--text-lg); color: var(--ink-muted); margin-bottom: 24px; }
  .section__sub--gap { margin-top: 64px; }

  /* griglie asimmetriche: i contenuti non partono mai da bordo a bordo simmetrico */
  .cards-2 { display: grid; gap: 24px; grid-template-columns: 1fr; }
  .cards-3 { display: grid; gap: 24px; grid-template-columns: 1fr; }
  @media (min-width: 720px) { .cards-2 { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 900px) { .cards-3 { grid-template-columns: repeat(3, 1fr); } }

  .skills { margin-top: 56px; }
  .skills ul { display: flex; flex-wrap: wrap; gap: 8px; list-style: none; padding: 0; margin: 14px 0 0; }

  .about-grid { display: grid; gap: 40px; grid-template-columns: 1fr; align-items: start; }
  @media (min-width: 900px) { .about-grid { grid-template-columns: 5fr 7fr; } } /* griglia 5/7 */
  .about-grid__media { border-radius: var(--radius-lg); overflow: hidden; background: var(--clay-300); }
  .about-grid__media :global(img) { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 4 / 5; }
  .about-grid__placeholder {
    aspect-ratio: 4 / 5; display: flex; align-items: center; justify-content: center;
    background: var(--bg-elev);
  }
  .about-grid__text p { margin-bottom: 18px; color: var(--ink-muted); max-width: 65ch; }
  .about-grid__text .section__head { margin-bottom: 24px; }
  .about-coach { margin: 36px 0 16px; }

  .contact { max-width: 640px; margin-inline: auto; text-align: center; }
  .contact h2 { margin: 12px 0 18px; }

  /* Form contatti */
  .contact-form { margin-top: 36px; text-align: left; display: grid; gap: 16px; }
  .contact-form__row { display: grid; gap: 16px; grid-template-columns: 1fr; }
  @media (min-width: 560px) { .contact-form__row { grid-template-columns: 1fr 1fr; } }
  .contact-form label { display: grid; gap: 6px; }
  .contact-form label span {
    font-family: var(--font-mono); font-size: var(--text-xs);
    letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-muted);
  }
  .contact-form input, .contact-form textarea {
    width: 100%;
    background: var(--bg-elev);
    border: var(--stroke) solid var(--border-strong);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    color: var(--ink);
    font: inherit;
    transition: border-color var(--dur) var(--ease-soft);
  }
  .contact-form input:focus, .contact-form textarea:focus { border-color: var(--accent); outline: none; }
  .contact-form textarea { resize: vertical; min-height: 110px; }
  .contact-form button { justify-self: start; }
  .contact-form__status { font-size: var(--text-sm); margin: 4px 0 0; min-height: 1.2em; }
  .contact-form__status.is-ok { color: var(--primary); }
  .contact-form__status.is-error { color: #b4502f; }

  .contact__or {
    margin-top: 32px; font-family: var(--font-mono); font-size: var(--text-xs);
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-faint);
  }
  .contact__actions { margin-top: 16px; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
</style>
