---
// Griglia masonry + lightbox accessibile per una galleria completa.
// Le immagini sono ottimizzate da Astro (<Image> → AVIF/WebP responsive,
// loading="lazy"). Il lightbox è vanilla JS: tastiera (←/→/Esc), preload del
// frame adiacente, focus gestito.
import { Image, getImage } from 'astro:assets';
import { getGallery } from '../lib/galleries';
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { slug: string; lang: Lang }
const { slug, lang } = Astro.props;
const t = useTranslations(lang);
const images = getGallery(slug);

// Per il lightbox generiamo una variante WebP limitata a 1600px (non l'originale
// a piena risoluzione): nitida a schermo intero ma leggera, e non emette i file
// sorgente nella build.
const lightboxData = await Promise.all(
  images.map(async (img) => {
    const big = await getImage({
      src: img.src,
      width: Math.min(img.src.width, 1600),
      format: 'webp',
      quality: 80,
    });
    return { src: big.src, alt: img.alt };
  })
);
---

{images.length === 0 ? (
  <p class="lead">{t('gallery.empty')}</p>
) : (
  <div class="masonry" id="gallery" data-count={images.length}>
    {images.map((img, i) => (
      <button
        class="gallery-item"
        type="button"
        data-index={i}
        aria-label={`${t('lightbox.next')} ${i + 1}/${images.length}`}
      >
        <Image
          src={img.src}
          alt={img.alt}
          widths={[400, 720, 1080]}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
          loading={i < 6 ? 'eager' : 'lazy'}
        />
      </button>
    ))}
  </div>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Gallery viewer" hidden>
    <button class="lightbox__btn lightbox__close" id="lb-close" aria-label={t('lightbox.close')}>✕</button>
    <button class="lightbox__btn lightbox__prev" id="lb-prev" aria-label={t('lightbox.prev')}>←</button>
    <figure class="lightbox__stage"><img id="lb-img" alt="" /></figure>
    <button class="lightbox__btn lightbox__next" id="lb-next" aria-label={t('lightbox.next')}>→</button>
    <p class="lightbox__hint">{t('lightbox.hint')}</p>
  </div>

  <!-- Sorgenti full-res (le versioni ottimizzate più grandi) per il lightbox -->
  <script type="application/json" id="lb-data" set:html={JSON.stringify(lightboxData)} />
)}

<style>
  .lightbox {
    position: fixed; inset: 0; z-index: 9500;
    display: flex; align-items: center; justify-content: center;
    background: color-mix(in srgb, var(--bg) 94%, #000);
    padding: clamp(16px, 4vw, 64px);
  }
  .lightbox[hidden] { display: none; }
  .lightbox__stage { margin: 0; max-width: 92vw; max-height: 86vh; }
  .lightbox__stage img {
    max-width: 92vw; max-height: 86vh; width: auto; height: auto;
    object-fit: contain; border-radius: var(--radius-sm);
  }
  .lightbox__btn {
    position: absolute;
    background: transparent;
    border: var(--stroke) solid var(--border-strong);
    color: var(--ink);
    width: 48px; height: 48px; border-radius: 50%;
    font-size: 1.1rem; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: border-color var(--dur), background var(--dur);
  }
  .lightbox__btn:hover { border-color: var(--accent); background: var(--bg-elev); }
  .lightbox__close { top: 20px; right: 20px; }
  .lightbox__prev { left: 20px; top: 50%; transform: translateY(-50%); }
  .lightbox__next { right: 20px; top: 50%; transform: translateY(-50%); }
  .lightbox__hint {
    position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em;
    color: var(--ink-faint);
  }
  @media (max-width: 640px) {
    .lightbox__prev { left: 8px; } .lightbox__next { right: 8px; }
  }
</style>

<script>
  const dataEl = document.getElementById('lb-data');
  if (dataEl) {
    const items: { src: string; alt: string }[] = JSON.parse(dataEl.textContent || '[]');
    const lb = document.getElementById('lightbox')!;
    const img = document.getElementById('lb-img') as HTMLImageElement;
    const grid = document.getElementById('gallery')!;
    let current = 0;
    let lastFocus: HTMLElement | null = null;

    const preload = (i: number) => { if (items[i]) new Image().src = items[i].src; };

    function show(i: number) {
      current = (i + items.length) % items.length;
      img.src = items[current].src;
      img.alt = items[current].alt;
      preload(current + 1); preload(current - 1);
    }
    function open(i: number) {
      lastFocus = document.activeElement as HTMLElement;
      show(i);
      lb.hidden = false;
      document.body.style.overflow = 'hidden';
      (document.getElementById('lb-next') as HTMLElement)?.focus();
    }
    function close() {
      lb.hidden = true;
      document.body.style.overflow = '';
      lastFocus?.focus();
    }

    grid.querySelectorAll('.gallery-item').forEach((btn) =>
      btn.addEventListener('click', () => open(Number((btn as HTMLElement).dataset.index)))
    );
    document.getElementById('lb-close')?.addEventListener('click', close);
    document.getElementById('lb-prev')?.addEventListener('click', () => show(current - 1));
    document.getElementById('lb-next')?.addEventListener('click', () => show(current + 1));
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowRight') show(current + 1);
      else if (e.key === 'ArrowLeft') show(current - 1);
    });
  }
</script>
