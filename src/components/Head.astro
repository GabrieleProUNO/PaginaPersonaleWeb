---
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  title: string;
  description: string;
}
const { lang, title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

// Percorsi gemelli IT/EN per gli hreflang alternate.
const path = Astro.url.pathname;
const itPath = path.replace(/^\/en(\/|$)/, '/');
const enPath = path.startsWith('/en') ? path : '/en' + (path === '/' ? '' : path);
const itHref = new URL(itPath, Astro.site);
const enHref = new URL(enPath, Astro.site);

// Dati strutturati (JSON-LD): aiutano Google a capire che il sito è di
// Gabriele Pittui (persona reale, profilo Instagram, città, competenze).
// Inseriti solo in home per evitare duplicazioni.
const isHome = path === '/' || path === '/en' || path === '/en/';
const siteUrl = Astro.site?.toString() ?? '';
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Gabriele Pittui',
  alternateName: 'Pittui Gabriele',
  url: siteUrl,
  image: new URL('/og-image.jpg', Astro.site).toString(),
  jobTitle:
    lang === 'en'
      ? 'Photographer, videomaker and software developer'
      : 'Fotografo, videomaker e sviluppatore',
  email: 'mailto:pittuigabriele@gmail.com',
  sameAs: ['https://www.instagram.com/pittui_gabriele'],
  worksFor: { '@type': 'Organization', name: 'Prugna Studio' },
  alumniOf: { '@type': 'EducationalOrganization', name: 'ITT G. Marconi, Rovereto' },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Rovereto',
    addressRegion: 'TN',
    addressCountry: 'IT',
  },
  knowsAbout: [
    'Fotografia', 'Videomaking', 'Sviluppo software', 'Reti Cisco',
    'Unity', 'C#', 'Python', 'Java',
  ],
};
const siteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Gabriele Pittui — Prugna Studio',
  url: siteUrl,
  inLanguage: lang === 'en' ? 'en' : 'it',
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="it" href={itHref} />
<link rel="alternate" hreflang="en" href={enHref} />
<link rel="alternate" hreflang="x-default" href={itHref} />
<meta name="generator" content={Astro.generator} />

<!-- Dati strutturati per i motori di ricerca (solo home) -->
{isHome && <script type="application/ld+json" set:html={JSON.stringify(personLd)} />}
{isHome && <script type="application/ld+json" set:html={JSON.stringify(siteLd)} />}

<!-- Favicon (logo Prugna Studio) -->
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
<meta name="theme-color" content="#16181C" />
<meta property="og:image" content={new URL('/og-image.jpg', Astro.site)} />
<meta property="og:url" content={canonical} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:locale" content={lang === 'it' ? 'it_IT' : 'en_US'} />
<meta name="twitter:card" content="summary_large_image" />

<!-- Font: precaricamento e caricamento (Google Fonts) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500;700&family=Shippori+Mincho:wght@500&display=swap"
  rel="stylesheet"
/>

<!-- Imposta la modalità (Luce/Logica) prima del paint per evitare flash. -->
<script is:inline>
  (function () {
    try {
      var saved = localStorage.getItem('gp-mode');
      var mode = saved || 'luce';
      document.documentElement.setAttribute('data-mode', mode);
    } catch (e) {
      document.documentElement.setAttribute('data-mode', 'luce');
    }
  })();
</script>
