---
import Base from '../../layouts/Base.astro';
import PageGallery from '../../components/PageGallery.astro';
import { collaborations, exhibitions, galleryTitle } from '../../data/content';

export function getStaticPaths() {
  return [...collaborations, ...exhibitions].map((g) => ({ params: { slug: g.slug } }));
}

const { slug } = Astro.params;
const title = galleryTitle(slug!, 'it');
---

<Base lang="it" title={`${title} — Gabriele Pittui`} description={`Galleria fotografica: ${title}. Portfolio di Gabriele Pittui.`}>
  <PageGallery slug={slug!} lang="it" />
</Base>
